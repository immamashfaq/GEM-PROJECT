# =============================================================================
# GEM PROJECT — API Environment Variables
# Copy this file to .env in apps/api/
# =============================================================================

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_VERSION=v1
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://gem_user:gem_password_change_me@localhost:5432/gem_db?schema=public"

# Redis
REDIS_URL="redis://:gem_redis_pass_change_me@localhost:6379"

# JWT Secrets — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=your_jwt_access_secret_change_me_min_64_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_me_min_64_chars

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Cloudinary (public image/video uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS S3 or MinIO (private KYC document storage)
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_BUCKET_KYC=gem-kyc-private
S3_ACCESS_KEY=gem_minio_user
S3_SECRET_KEY=gem_minio_pass_change_me

# App URLs
WEB_URL=http://localhost:3000

# Email (optional in Phase 1 — structure is ready)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@gemproject.lk
SMTP_PASS=your_smtp_password
EMAIL_FROM="Gem Project <noreply@gemproject.lk>"

# Platform fee percentage (e.g., 5 = 5%)
PLATFORM_FEE_PERCENT=5

# Live Streaming Provider (mock | mux)
STREAM_PROVIDER=mock
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret

# Optional: Local/Offline RTMP testing configuration (e.g. using the nginx-rtmp container)
MOCK_RTMP_URL=rtmp://localhost:1935/stream
MOCK_PLAYBACK_URL=http://localhost:8080/live/



