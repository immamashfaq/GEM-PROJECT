{
  "expo": {
    "name": "Gem Project",
    "slug": "gem-project",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "gemproject",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080d1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "lk.gemproject.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080d1a"
      },
      "package": "lk.gemproject.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Gem Project needs access to your photos to upload gem images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
