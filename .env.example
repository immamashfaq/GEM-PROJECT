# =============================================================================
# GEM PROJECT — Root Environment Variables
# Copy this file to .env at the root for Docker Compose to pick up.
# =============================================================================

# PostgreSQL
POSTGRES_USER=gem_user
POSTGRES_PASSWORD=gem_password_change_me
POSTGRES_DB=gem_db

# Redis
REDIS_PASSWORD=gem_redis_pass_change_me

# MinIO (local S3-compatible storage)
MINIO_ROOT_USER=gem_minio_user
MINIO_ROOT_PASSWORD=gem_minio_pass_change_me
